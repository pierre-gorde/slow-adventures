---
import { getCollection } from 'astro:content';
import { regionOrder, regionLabels } from '../data/regions';

interface Props {
  dark?: boolean;
}

const { dark = false } = Astro.props;

const allDestinations = await getCollection('destinations');
const destinations = allDestinations.filter((d) => !d.data.draft);
const sorted = [...destinations].sort((a, b) => a.data.order - b.data.order);

const grouped = regionOrder
  .map((r) => ({
    region: r,
    label: regionLabels[r],
    destinations: sorted.filter((d) => d.data.region === r),
  }))
  .filter((g) => g.destinations.length > 0);

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '';
---

<nav
  id="topbar"
  class={`topbar fixed top-0 left-0 right-0 z-40 transition-all duration-300${dark ? ' topbar--dark' : ''}`}
  aria-label="Navigation principale"
>
  <div class="topbar__inner flex items-center justify-between px-5 py-3 md:px-8">
    <!-- Logo / Home link -->
    <a
      href="/"
      class="topbar__logo font-serif text-lg tracking-wide transition-colors"
      aria-label="Slow Adventures — Accueil"
    >
      Slow Adventures
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      <!-- Destinations dropdown -->
      <div class="topbar__dropdown relative">
        <a
          href="/destinations/"
          class="topbar__link topbar__dropdown-trigger font-sans text-sm transition-colors inline-flex items-center gap-1 cursor-pointer"
          aria-haspopup="true"
        >
          Destinations
          <svg class="w-3.5 h-3.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m6 9 6 6 6-6" />
          </svg>
        </a>
        <div class="topbar__dropdown-panel absolute top-full right-0 mt-2 w-72 rounded-xl overflow-hidden opacity-0 invisible transition-all duration-200">
          <div class="bg-white shadow-lg border border-warm-black/5 rounded-xl p-3 max-h-[70vh] overflow-y-auto">
            {grouped.map((group) => (
              <div class="mb-1">
                <p class="font-sans text-[10px] uppercase tracking-widest text-warm-black/40 px-3 pt-2 pb-1">
                  {group.label}
                </p>
                {group.destinations.map((d) => (
                  <a
                    href={`/destinations/${d.slug}/`}
                    class={`topbar__dropdown-link flex items-center gap-3 px-3 py-2 rounded-lg font-sans text-sm transition-colors ${
                      currentPath.includes(d.slug) ? 'topbar__dropdown-link--active' : ''
                    }`}
                  >
                    <span class="text-warm-black">{d.data.country}</span>
                  </a>
                ))}
              </div>
            ))}
            <div class="mt-1 pt-2 border-t border-warm-black/5">
              <a
                href="/destinations/"
                class="topbar__dropdown-link flex items-center gap-2 px-3 py-2 rounded-lg font-sans text-xs text-warm-black/50 transition-colors"
              >
                Voir toutes les destinations
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <a
        href={import.meta.env.PUBLIC_CALENDLY_URL ?? '/#tarifs'}
        data-calendly-trigger
        class="topbar__cta font-sans text-xs uppercase tracking-widest px-4 py-2 rounded-full border transition-colors"
      >
        Confie-moi ton prochain rêve
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      type="button"
      id="topbar-toggle"
      class="md:hidden topbar__hamburger relative w-8 h-8 flex items-center justify-center cursor-pointer"
      aria-expanded="false"
      aria-controls="topbar-menu"
      aria-label="Ouvrir le menu"
    >
      <span class="topbar__bar topbar__bar--1"></span>
      <span class="topbar__bar topbar__bar--2"></span>
      <span class="topbar__bar topbar__bar--3"></span>
    </button>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="topbar-menu"
    class="topbar__menu md:hidden overflow-hidden transition-all duration-300"
    aria-hidden="true"
  >
    <div class="px-5 pb-6 pt-2 flex flex-col h-full">
      <!-- Accueil -->
      <a
        href="/"
        class={`topbar__menu-link font-sans text-base py-3 px-3 rounded-lg transition-colors ${
          isHome ? 'topbar__menu-link--active' : ''
        }`}
      >
        Accueil
      </a>

      <!-- Destinations group -->
      <div class="mt-3 flex-1 flex flex-col min-h-0">
        <!-- Search input -->
        <div class="relative px-3 mb-2">
          <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-4 h-4 text-warm-black/30 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.3-4.3" />
          </svg>
          <input
            type="text"
            id="dest-search"
            class="topbar__search w-full pl-8 pr-3 py-2 rounded-lg bg-warm-black/4 font-sans text-sm text-warm-black placeholder:text-warm-black/35 outline-none focus:ring-1 focus:ring-terracotta/30"
            placeholder="Rechercher un pays..."
            autocomplete="off"
          />
        </div>

        <!-- Destination links grouped by region -->
        <div id="dest-list" class="flex-1 overflow-y-auto min-h-0">
          {grouped.map((group) => (
            <div class="topbar__dest-group" data-region={group.region}>
              <p class="font-sans text-[10px] uppercase tracking-widest text-warm-black/40 px-3 pt-2 pb-1">
                {group.label}
              </p>
              {group.destinations.map((d) => (
                <a
                  href={`/destinations/${d.slug}/`}
                  class={`topbar__menu-link topbar__dest-link font-sans text-base py-3 px-3 rounded-lg transition-colors block ${
                    currentPath.includes(d.slug) ? 'topbar__menu-link--active' : ''
                  }`}
                  data-country={d.data.country.toLowerCase()}
                >
                  {d.data.country}
                </a>
              ))}
            </div>
          ))}
          <p
            id="dest-no-result"
            class="hidden font-sans text-sm text-warm-black/40 py-3 px-3"
          >
            Aucune destination trouvée
          </p>
        </div>

        <a
          href="/destinations/"
          class="topbar__menu-link font-sans text-sm py-2.5 px-3 rounded-lg transition-colors text-warm-black/50 inline-flex items-center gap-1.5 mt-1"
        >
          Voir toutes les destinations
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <!-- CTA -->
      <div class="mt-auto pt-3 border-t border-warm-black/10">
        <a
          href={import.meta.env.PUBLIC_CALENDLY_URL ?? '/#tarifs'}
          data-calendly-trigger
          class="topbar__menu-cta block text-center font-sans text-sm uppercase tracking-widest py-3 px-4 rounded-full transition-colors"
        >
          Confie-moi ton prochain rêve
        </a>
      </div>
    </div>
  </div>
</nav>

<div id="topbar-spacer" class="h-0 transition-all duration-300"></div>

<style>
  /* ── Base state: transparent over hero ── */
  .topbar {
    background: transparent;
  }

  .topbar__logo {
    color: white;
  }

  .topbar__link {
    color: rgba(255, 255, 255, 0.75);
  }

  .topbar__link:hover,
  .topbar__link--active {
    color: white;
  }

  .topbar__cta {
    color: white;
    border-color: rgba(255, 255, 255, 0.4);
  }

  .topbar__cta:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.7);
  }

  /* Hamburger bars */
  .topbar__bar {
    position: absolute;
    width: 20px;
    height: 2px;
    background: white;
    border-radius: 1px;
    transition: all 0.3s ease;
  }

  .topbar__bar--1 { transform: translateY(-6px); }
  .topbar__bar--2 { transform: translateY(0); }
  .topbar__bar--3 { transform: translateY(6px); }

  /* Mobile menu (closed) */
  .topbar__menu {
    max-height: 0;
  }

  .topbar__menu-link {
    color: var(--color-warm-black);
  }

  .topbar__menu-link:hover,
  .topbar__menu-link--active {
    background: color-mix(in srgb, var(--color-terracotta) 8%, transparent);
    color: var(--color-terracotta);
  }

  .topbar__menu-cta {
    background: var(--color-terracotta);
    color: white;
  }

  .topbar__menu-cta:hover {
    background: color-mix(in srgb, var(--color-terracotta) 85%, black);
  }

  /* ── Desktop dropdown ── */
  .topbar__dropdown:hover .topbar__dropdown-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .topbar__dropdown-panel {
    transform: translateY(-4px);
  }

  .topbar__dropdown:hover .topbar__dropdown-trigger svg {
    transform: rotate(180deg);
  }

  .topbar__dropdown-link {
    color: var(--color-warm-black);
  }

  .topbar__dropdown-link:hover,
  .topbar__dropdown-link--active {
    background: color-mix(in srgb, var(--color-terracotta) 6%, transparent);
    color: var(--color-terracotta);
  }

  /* ── Dark variant (pages without dark hero) ── */
  .topbar--dark .topbar__logo {
    color: var(--color-warm-black);
  }

  .topbar--dark .topbar__link {
    color: color-mix(in srgb, var(--color-warm-black) 60%, transparent);
  }

  .topbar--dark .topbar__link:hover,
  .topbar--dark .topbar__link--active {
    color: var(--color-terracotta);
  }

  .topbar--dark .topbar__cta {
    color: var(--color-terracotta);
    border-color: var(--color-terracotta);
  }

  .topbar--dark .topbar__cta:hover {
    background: color-mix(in srgb, var(--color-terracotta) 8%, transparent);
  }

  .topbar--dark .topbar__bar {
    background: var(--color-warm-black);
  }

  /* ── Scrolled state ── */
  .topbar--scrolled {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.06);
  }

  .topbar--scrolled .topbar__logo {
    color: var(--color-warm-black);
  }

  .topbar--scrolled .topbar__link {
    color: color-mix(in srgb, var(--color-warm-black) 60%, transparent);
  }

  .topbar--scrolled .topbar__link:hover,
  .topbar--scrolled .topbar__link--active {
    color: var(--color-terracotta);
  }

  .topbar--scrolled .topbar__cta {
    color: var(--color-terracotta);
    border-color: var(--color-terracotta);
  }

  .topbar--scrolled .topbar__cta:hover {
    background: color-mix(in srgb, var(--color-terracotta) 8%, transparent);
  }

  .topbar--scrolled .topbar__bar {
    background: var(--color-warm-black);
  }

  /* ── Menu open state ── */
  .topbar--open {
    background: white;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .topbar--open .topbar__logo {
    color: var(--color-warm-black);
  }

  .topbar--open .topbar__bar {
    background: var(--color-warm-black);
  }

  .topbar--open .topbar__bar--1 {
    transform: rotate(45deg);
  }

  .topbar--open .topbar__bar--2 {
    opacity: 0;
  }

  .topbar--open .topbar__bar--3 {
    transform: rotate(-45deg);
  }

  .topbar--open {
    height: 100dvh;
    height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .topbar--open .topbar__menu {
    max-height: none;
    flex: 1;
    overflow-y: auto;
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .topbar,
    .topbar__menu,
    .topbar__bar,
    .topbar__dropdown-panel {
      transition: none;
    }
  }
</style>

<script>
  const topbar = document.getElementById('topbar');
  const toggle = document.getElementById('topbar-toggle');
  const menu = document.getElementById('topbar-menu');
  const searchInput = document.getElementById('dest-search') as HTMLInputElement | null;
  const destLinks = document.querySelectorAll<HTMLElement>('.topbar__dest-link');
  const noResult = document.getElementById('dest-no-result');

  let isOpen = false;

  function closeMenu() {
    if (!toggle || !topbar || !menu) return;
    isOpen = false;
    topbar.classList.remove('topbar--open');
    toggle.setAttribute('aria-expanded', 'false');
    menu.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-label', 'Ouvrir le menu');
  }

  // Toggle mobile menu
  if (toggle && topbar && menu) {
    toggle.addEventListener('click', () => {
      isOpen = !isOpen;
      topbar.classList.toggle('topbar--open', isOpen);
      toggle.setAttribute('aria-expanded', String(isOpen));
      menu.setAttribute('aria-hidden', String(!isOpen));
      toggle.setAttribute(
        'aria-label',
        isOpen ? 'Fermer le menu' : 'Ouvrir le menu',
      );
      // Focus search on open
      if (isOpen && searchInput) {
        setTimeout(() => searchInput.focus(), 150);
      }
    });
  }

  // Scroll: transparent -> solid
  function onScroll() {
    if (!topbar) return;
    const scrolled = window.scrollY > 80;
    topbar.classList.toggle('topbar--scrolled', scrolled && !isOpen);
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Close menu on link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (isOpen) closeMenu();
    });
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) {
      closeMenu();
      toggle?.focus();
    }
  });

  // ── Destination search filter (accent-insensitive) ──
  const normalize = (s: string) =>
    s.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim();

  const destGroups = document.querySelectorAll<HTMLElement>('.topbar__dest-group');

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const query = normalize(searchInput.value);
      let visibleCount = 0;

      destLinks.forEach((link) => {
        const country = normalize(link.dataset.country ?? '');
        const match = !query || country.includes(query);
        link.style.display = match ? '' : 'none';
        if (match) visibleCount++;
      });

      // Hide region headers when no destinations match in that group
      destGroups.forEach((group) => {
        const hasVisible = group.querySelectorAll<HTMLElement>('.topbar__dest-link');
        let groupVisible = false;
        hasVisible.forEach((link) => {
          if (link.style.display !== 'none') groupVisible = true;
        });
        group.style.display = groupVisible || !query ? '' : 'none';
      });

      if (noResult) {
        noResult.classList.toggle('hidden', visibleCount > 0);
      }
    });
  }
</script>
