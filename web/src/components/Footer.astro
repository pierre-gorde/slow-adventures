---
const currentYear = new Date().getFullYear();
---

<footer class="bg-warm-black py-8" aria-label="Pied de page">
  <div
    class="max-w-[640px] mx-auto px-6 flex flex-col items-center gap-4 lg:flex-row lg:justify-center lg:gap-6"
  >
    <nav
      aria-label="Liens du pied de page"
      class="flex flex-col items-center gap-4 lg:flex-row lg:gap-6"
    >
      <a
        href="/mentions-legales"
        class="text-white/60 text-sm hover:underline transition-colors hover:text-white min-h-11 inline-flex items-center"
        >Mentions légales</a
      >
      <a
        href="/politique-confidentialite"
        class="text-white/60 text-sm hover:underline transition-colors hover:text-white min-h-11 inline-flex items-center"
        >Politique de confidentialité</a
      >
      <a
        href="mailto:elena.ld83@gmail.com"
        class="text-white/60 text-sm hover:underline transition-colors hover:text-white min-h-11 inline-flex items-center"
        >elena.ld83@gmail.com</a
      >
      <a
        href="https://www.instagram.com/slow_adventures_/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram Slow Adventures (@slow_adventures_)"
        class="text-white/60 text-sm hover:text-white transition-colors min-h-11 inline-flex items-center gap-1.5"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
          <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"></circle>
        </svg>
        @slow_adventures_
      </a>
    </nav>
    <span class="text-white/60 text-sm"
      >&copy; {currentYear} Slow Adventures</span
    >
  </div>
</footer>
