---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  images: ImageMetadata[];
  country: string;
}

const { images, country } = Astro.props;

/* Show up to 4 images in the mosaic grid, rest behind "Voir les X photos" */
const visibleCount = Math.min(images.length, 4);
const visibleImages = images.slice(0, visibleCount);
const totalCount = images.length;
const hiddenCount = totalCount - visibleCount;

/* Pre-optimize ALL images for the lightbox (not just visible ones) */
const allOptimized = await Promise.all(
  images.map((img) => getImage({ src: img, width: 1440, format: 'webp' })),
);
const allSrcs = allOptimized.map((o) => o.src);
---

<section
  class="dest-gallery bg-white px-4 py-8 md:px-8 md:py-12"
  aria-label={`Photos de ${country}`}
  data-gallery-srcs={JSON.stringify(allSrcs)}
>
  <div class="max-w-5xl mx-auto">
    {/* ── Mosaic grid: 4 cols x 2 rows (WeRoad style) ── */}
    <div class="dest-gallery__grid grid grid-cols-4 grid-rows-2 h-64 md:h-100 gap-1 rounded-xl overflow-hidden">
      {visibleImages.map((img, i) => {
        /* Cell 0: 2 cols x 2 rows (hero large)
           Cell 1: 1 col x 2 rows (tall portrait)
           Cell 2: 1 col x 1 row (top-right)
           Cell 3: 1 col x 1 row (bottom-right) + overlay */
        const spanClass =
          i === 0
            ? 'col-span-2 row-span-2'
            : i === 1
              ? 'col-span-1 row-span-2'
              : 'col-span-1 row-span-1';

        return (
          <button
            type="button"
            class={`dest-gallery__item relative overflow-hidden cursor-pointer group ${spanClass}`}
            data-gallery-index={i}
            aria-label={`Photo ${i + 1} de ${country} — cliquer pour agrandir`}
          >
            <Image
              src={img}
              alt={`${country} — photo ${i + 1}`}
              widths={[400, 800, 1200]}
              sizes={i === 0 ? '50vw' : '25vw'}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            {/* "Voir les X photos" overlay on last visible cell */}
            {i === visibleCount - 1 && hiddenCount > 0 && (
              <div class="absolute inset-0 bg-warm-black/45 flex items-center justify-center transition-colors group-hover:bg-warm-black/55">
                <span class="font-sans text-white text-sm md:text-base font-medium tracking-wide">
                  Voir les {totalCount} photos
                </span>
              </div>
            )}
          </button>
        );
      })}
    </div>

    {/* Button below grid when all images are already visible */}
    {hiddenCount <= 0 && totalCount > 1 && (
      <div class="text-center mt-5">
        <button
          type="button"
          class="dest-gallery__trigger font-sans text-sm text-warm-black/60 hover:text-terracotta transition-colors inline-flex items-center gap-2"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
            <circle cx="8.5" cy="8.5" r="1.5" />
            <path d="m21 15-5-5L5 21" />
          </svg>
          Voir les {totalCount} photos
        </button>
      </div>
    )}
  </div>
</section>

<!-- ═══ Fullscreen lightbox / slider ═══ -->
<div
  id="gallery-lightbox"
  class="fixed inset-0 z-50 bg-warm-black/95 hidden"
  role="dialog"
  aria-modal="true"
  aria-label={`Galerie photos ${country}`}
>
  <!-- Close -->
  <button
    type="button"
    id="lightbox-close"
    class="absolute top-4 right-4 z-10 text-white/70 hover:text-white transition-colors p-2 cursor-pointer"
    aria-label="Fermer la galerie"
  >
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 6 6 18M6 6l12 12" />
    </svg>
  </button>

  <!-- Counter -->
  <div
    id="lightbox-counter"
    class="absolute top-5 left-6 font-sans text-white/60 text-sm z-10"
    aria-live="polite"
  ></div>

  <!-- Previous -->
  <button
    type="button"
    id="lightbox-prev"
    class="absolute left-2 md:left-4 top-1/2 -translate-y-1/2 text-white/50 hover:text-white transition-colors p-2 md:p-3 z-10 cursor-pointer"
    aria-label="Photo précédente"
  >
    <svg class="w-7 h-7 md:w-9 md:h-9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M15 18l-6-6 6-6" />
    </svg>
  </button>

  <!-- Slide container -->
  <div
    id="lightbox-track"
    class="absolute inset-0 flex items-center justify-center overflow-hidden touch-pan-y"
  >
    <img
      id="lightbox-img"
      src=""
      alt=""
      class="lightbox-img max-w-[92vw] max-h-[85vh] object-contain select-none transition-transform duration-300 ease-out"
      draggable="false"
    />
  </div>

  <!-- Next -->
  <button
    type="button"
    id="lightbox-next"
    class="absolute right-2 md:right-4 top-1/2 -translate-y-1/2 text-white/50 hover:text-white transition-colors p-2 md:p-3 z-10 cursor-pointer"
    aria-label="Photo suivante"
  >
    <svg class="w-7 h-7 md:w-9 md:h-9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 18l6-6-6-6" />
    </svg>
  </button>
</div>

<style>
  .dest-gallery__item:focus-visible {
    outline: 2px solid var(--color-terracotta);
    outline-offset: -2px;
  }

  .lightbox-img {
    will-change: transform;
  }
</style>

<script>
  /* ── Gallery lightbox — shows ALL images (not just grid-visible ones) ── */
  const gallerySection = document.querySelector<HTMLElement>('.dest-gallery');
  const galleryTrigger = document.querySelector('.dest-gallery__trigger');
  const lightbox = document.getElementById('gallery-lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const lightboxCounter = document.getElementById('lightbox-counter');
  const lightboxTrack = document.getElementById('lightbox-track');
  const closeBtn = document.getElementById('lightbox-close');
  const prevBtn = document.getElementById('lightbox-prev');
  const nextBtn = document.getElementById('lightbox-next');

  // ALL image srcs from data attribute (includes hidden ones)
  const srcs: string[] = JSON.parse(
    gallerySection?.dataset.gallerySrcs ?? '[]',
  );

  let current = 0;

  function show(index: number) {
    current = ((index % srcs.length) + srcs.length) % srcs.length;
    if (lightboxImg) {
      lightboxImg.src = srcs[current];
      lightboxImg.alt = `Photo ${current + 1}`;
      lightboxImg.style.transform = 'translateX(0)';
    }
    if (lightboxCounter) {
      lightboxCounter.textContent = `${current + 1} / ${srcs.length}`;
    }
  }

  function open(index: number) {
    show(index);
    if (lightbox) {
      lightbox.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
  }

  function close() {
    if (lightbox) {
      lightbox.classList.add('hidden');
      document.body.style.overflow = '';
    }
  }

  // Grid item clicks
  document.querySelectorAll<HTMLElement>('[data-gallery-index]').forEach((btn) => {
    btn.addEventListener('click', () => {
      open(parseInt(btn.dataset.galleryIndex ?? '0', 10));
    });
  });

  if (galleryTrigger) galleryTrigger.addEventListener('click', () => open(0));
  if (closeBtn) closeBtn.addEventListener('click', close);
  if (prevBtn) prevBtn.addEventListener('click', () => show(current - 1));
  if (nextBtn) nextBtn.addEventListener('click', () => show(current + 1));

  // Click on backdrop to close
  if (lightboxTrack) {
    lightboxTrack.addEventListener('click', (e) => {
      if (e.target === lightboxTrack) close();
    });
  }

  /* ── Keyboard navigation (arrows + Escape) ── */
  document.addEventListener('keydown', (e) => {
    if (!lightbox || lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowLeft') show(current - 1);
    if (e.key === 'ArrowRight') show(current + 1);
  });

  /* ── Touch swipe on mobile ── */
  let touchStartX = 0;
  let touchDeltaX = 0;
  let isSwiping = false;

  if (lightboxTrack) {
    lightboxTrack.addEventListener(
      'touchstart',
      (e: TouchEvent) => {
        touchStartX = e.touches[0].clientX;
        touchDeltaX = 0;
        isSwiping = true;
        if (lightboxImg) lightboxImg.style.transition = 'none';
      },
      { passive: true },
    );

    lightboxTrack.addEventListener(
      'touchmove',
      (e: TouchEvent) => {
        if (!isSwiping) return;
        touchDeltaX = e.touches[0].clientX - touchStartX;
        if (lightboxImg) {
          lightboxImg.style.transform = `translateX(${touchDeltaX}px)`;
        }
      },
      { passive: true },
    );

    lightboxTrack.addEventListener('touchend', () => {
      if (!isSwiping) return;
      isSwiping = false;
      if (lightboxImg) lightboxImg.style.transition = 'transform 0.3s ease-out';

      const threshold = 60;
      if (touchDeltaX < -threshold) {
        show(current + 1);
      } else if (touchDeltaX > threshold) {
        show(current - 1);
      } else {
        if (lightboxImg) lightboxImg.style.transform = 'translateX(0)';
      }
    });
  }
</script>
