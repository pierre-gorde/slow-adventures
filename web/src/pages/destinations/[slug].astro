---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import CalendlyModal from '../../components/CalendlyModal.astro';
import SectionReveal from '../../components/SectionReveal.astro';
import ScrollHint from '../../components/ScrollHint.astro';
import DestinationGallery from '../../components/DestinationGallery.astro';

export async function getStaticPaths() {
  const allDestinations = await getCollection('destinations');
  const destinations = allDestinations.filter((d) => !d.data.draft);
  return destinations.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<'destinations'> };
const { entry } = Astro.props;

const pageTitle = entry.data.title ?? `${entry.data.country} — Slow Adventures`;
const pageDescription = entry.data.metaDescription ?? entry.data.description;

const isUrlImage = typeof entry.data.image === 'string';
const optimizedHero = isUrlImage
  ? null
  : await getImage({ src: entry.data.image, width: 1440, format: 'webp' });
const heroSrc = isUrlImage ? (entry.data.image as string) : optimizedHero?.src ?? '';

const gallery = entry.data.gallery ?? [];
const hasGallery = gallery.length > 0;

/* ── Parse markdown body into designed sections ── */
const rawBody = entry.body;
const parts = rawBody.split(/^## /m);
const introMd = parts[0].trim();
const introHtml = marked.parse(introMd);

interface ContentSection {
  title: string;
  html: string;
  bg: 'white' | 'cream';
}

const sectionBg: { pattern: RegExp; bg: 'white' | 'cream' }[] = [
  { pattern: /pourquoi/i, bg: 'cream' },
  { pattern: /ce qui t.attend/i, bg: 'white' },
  { pattern: /quand partir/i, bg: 'cream' },
  { pattern: /combien de temps/i, bg: 'white' },
  { pattern: /ce que je construis/i, bg: 'cream' },
];

const sections: ContentSection[] = [];
for (const part of parts.slice(1)) {
  const lines = part.split('\n');
  const title = lines[0].replace(/\s*$/, '');
  const body = lines.slice(1).join('\n').trim();
  const html = marked.parse(body) as string;

  const meta = sectionBg.find((m) => m.pattern.test(title));
  sections.push({
    title,
    html,
    bg: meta?.bg ?? 'white',
  });
}

const touristDestinationLd = {
  '@context': 'https://schema.org',
  '@type': 'TouristDestination',
  name: entry.data.country,
  description: pageDescription,
  url: Astro.url.toString(),
  touristType: {
    '@type': 'Audience',
    audienceType: 'Voyageurs indépendants, slow travellers',
  },
  offers: {
    '@type': 'Offer',
    name: "Création d'itinéraire sur mesure",
    url: import.meta.env.PUBLIC_CALENDLY_URL ?? 'https://slowadventures.fr',
    offeredBy: {
      '@type': 'Person',
      name: 'Elena',
      jobTitle: 'Travel Planner',
    },
  },
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  heroPreloadImage={heroSrc}
  ogImage={heroSrc}
  extraLd={touristDestinationLd}
>
  <main id="main">
    <!-- ═══════════════════════════════════════════════
         HERO FULLSCREEN
    ═══════════════════════════════════════════════ -->
    <section
      class="dest-hero relative overflow-hidden"
      aria-label={`Destination ${entry.data.country}`}
    >
      {isUrlImage ? (
        <img
          src={entry.data.image as string}
          alt={`Paysage de ${entry.data.country}`}
          loading="eager"
          decoding="async"
          class="dest-hero__img absolute inset-0 w-full h-full object-cover"
        />
      ) : (
        <Image
          src={entry.data.image as ImageMetadata}
          alt={`Paysage de ${entry.data.country}`}
          widths={[768, 1440, 2880]}
          sizes="100vw"
          loading="eager"
          decoding="async"
          class="dest-hero__img absolute inset-0 w-full h-full object-cover"
        />
      )}
      <div
        class="absolute inset-0 bg-linear-to-b from-warm-black/55 via-warm-black/15 to-warm-black/75"
        aria-hidden="true"
      >
      </div>

      <div
        class="dest-hero__content relative z-10 flex flex-col justify-end items-center text-center px-6 pb-28"
      >
        <div class="dest-hero__text">
          <p
            class="font-sans text-white/70 text-xs uppercase tracking-[0.25em] mb-4"
          >
            Slow Adventures · Travel Planning
          </p>
          <h1
            class="font-serif text-5xl md:text-7xl lg:text-8xl text-white leading-none mb-6"
          >
            {entry.data.country}
          </h1>
          <p
            class="font-sans text-white/85 text-lg md:text-xl max-w-2xl leading-relaxed mx-auto"
          >
            {entry.data.description}
          </p>
        </div>
      </div>

      <ScrollHint />
    </section>

    <!-- ═══════════════════════════════════════════════
         KEYWORDS CHIPS
    ═══════════════════════════════════════════════ -->
    {
      entry.data.keywords && entry.data.keywords.length > 0 && (
        <div
          class="bg-creme px-6 py-6 md:px-12 md:py-8"
          aria-label="Thèmes du voyage"
        >
          <div class="max-w-4xl mx-auto flex flex-wrap justify-center gap-2">
            {entry.data.keywords.map((keyword) => (
              <span class="font-sans text-xs px-3 py-1.5 rounded-full text-warm-black/50 bg-warm-black/4">
                {keyword}
              </span>
            ))}
          </div>
        </div>
      )
    }

    <!-- ═══════════════════════════════════════════════
         PHOTO GALLERY (conditionnel)
    ═══════════════════════════════════════════════ -->
    {
      hasGallery && (
        <DestinationGallery images={gallery} country={entry.data.country} />
      )
    }

    <!-- ═══════════════════════════════════════════════
         INTRO PARAGRAPH
    ═══════════════════════════════════════════════ -->
    {
      introHtml && (
        <section class="bg-white sa-section-padding" aria-label="Introduction">
          <SectionReveal animation="fade-up">
            <div class="max-w-3xl mx-auto dest-intro" set:html={introHtml} />
          </SectionReveal>
        </section>
      )
    }

    <!-- ═══════════════════════════════════════════════
         CONTENT SECTIONS (parsed from markdown h2)
    ═══════════════════════════════════════════════ -->
    {
      sections.map((section) => (
        <section
          class={`sa-section-padding ${section.bg === 'cream' ? 'bg-creme' : 'bg-white'}`}
          aria-label={section.title}
        >
          <SectionReveal animation="fade-up">
            <div class="max-w-3xl mx-auto">
              <h2 class="dest-section__header font-serif text-2xl md:text-3xl text-warm-black leading-tight mb-8 pb-3">
                {section.title}
              </h2>
              <div
                class="dest-section__body destination-content"
                set:html={section.html}
              />
            </div>
          </SectionReveal>
        </section>
      ))
    }

    <!-- ═══════════════════════════════════════════════
         CTA SECTION — Discovery Call
    ═══════════════════════════════════════════════ -->
    <section
      class="dest-cta-band sa-section-padding text-center"
      aria-labelledby="dest-cta-heading"
    >
      <SectionReveal animation="scale-in">
        <div class="max-w-2xl mx-auto">
          <p
            class="font-sans text-white/70 text-xs uppercase tracking-[0.2em] mb-5"
          >
            Travel Planning sur mesure
          </p>
          <h2
            id="dest-cta-heading"
            class="font-serif text-3xl md:text-4xl text-white mb-5"
          >
            Prêt(e) à partir ?
          </h2>
          <p class="font-sans text-white/85 text-lg mb-10 leading-relaxed">
            Dis-moi tes envies, tes contraintes, tes rêves — je m'occupe du
            reste.
          </p>
          <CTAButton
            href={import.meta.env.PUBLIC_CALENDLY_URL}
            variant="outline"
            text="Confie-moi ton prochain rêve"
            subtext="30 min, gratuit, sans engagement"
          />
        </div>
      </SectionReveal>
    </section>

    <!-- ═══════════════════════════════════════════════
         BACK LINK
    ═══════════════════════════════════════════════ -->
    <div class="text-center py-8 bg-creme">
      <a
        href="/destinations/"
        aria-label="Retour à toutes les destinations"
        class="inline-flex items-center gap-2 font-sans text-warm-black/60 hover:text-terracotta transition-colors text-sm"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M19 12H5M5 12l7 7M5 12l7-7"></path>
        </svg>
        Toutes les destinations
      </a>
    </div>
  </main>
  <CalendlyModal />
</BaseLayout>

<style>
  /* ── Hero ── */
  .dest-hero {
    min-height: 100svh;
    min-height: 100vh;
  }

  .dest-hero__content {
    min-height: 100svh;
    min-height: 100vh;
  }

  .dest-hero__text {
    opacity: 0;
    transform: translateY(32px);
    animation: hero-entrance 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
  }

  @keyframes hero-entrance {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Keywords chips — discret, pas interactif ── */

  /* ── Intro paragraph — lead style ── */
  .dest-intro :global(p) {
    font-family: var(--font-sans);
    font-size: 1.2rem;
    line-height: 1.9;
    color: color-mix(in srgb, var(--color-warm-black) 85%, transparent);
    margin-bottom: 1rem;
  }

  .dest-intro :global(p:first-of-type) {
    font-size: 1.3rem;
  }

  /* ── Section headers ── */
  .dest-section__header {
    border-bottom: 2px solid
      color-mix(in srgb, var(--color-terracotta) 15%, transparent);
  }

  /* ── Section body — prose ── */
  .destination-content :global(p) {
    margin-bottom: 1.25rem;
    line-height: 1.85;
    color: var(--color-warm-black);
    font-size: 1.0625rem;
  }

  .destination-content :global(ul),
  .destination-content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 0;
    list-style: none;
  }

  .destination-content :global(li) {
    margin-bottom: 0.75rem;
    line-height: 1.75;
    color: var(--color-warm-black);
    padding-left: 1.75rem;
    position: relative;
  }

  .destination-content :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-terracotta) 50%, transparent);
  }

  .destination-content :global(strong) {
    font-weight: 700;
    color: var(--color-warm-black);
  }

  .destination-content :global(em) {
    font-style: italic;
    color: color-mix(
      in srgb,
      var(--color-terracotta) 80%,
      var(--color-warm-black)
    );
  }

  .destination-content :global(a) {
    color: var(--color-terracotta);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .destination-content :global(h3) {
    font-family: var(--font-bree);
    font-size: 1.15rem;
    color: var(--color-terracotta);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  /* ── CTA band ── */
  .dest-cta-band {
    background: linear-gradient(
      135deg,
      var(--color-terracotta) 0%,
      var(--color-ambre) 60%,
      color-mix(in srgb, var(--color-ambre) 70%, var(--color-sauge)) 100%
    );
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .dest-hero__text {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  import { gsap, ScrollTrigger } from '../../lib/gsap';

  const heroImg = document.querySelector<HTMLElement>('.dest-hero__img');
  if (heroImg) {
    gsap.to(heroImg, {
      yPercent: 20,
      ease: 'none',
      scrollTrigger: {
        trigger: '.dest-hero',
        start: 'top top',
        end: 'bottom top',
        scrub: 1,
      },
    });
  }

  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((st) => st.kill());
  });
</script>
