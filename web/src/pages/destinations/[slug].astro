---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import CalendlyModal from '../../components/CalendlyModal.astro';
import SectionReveal from '../../components/SectionReveal.astro';
import ScrollHint from '../../components/ScrollHint.astro';

export async function getStaticPaths() {
  const destinations = await getCollection('destinations');
  return destinations.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<'destinations'> };
const { entry } = Astro.props;
const { Content } = await entry.render();

const pageTitle = entry.data.title ?? `${entry.data.country} — Slow Adventures`;
const pageDescription = entry.data.metaDescription ?? entry.data.description;

const optimizedHero = await getImage({
  src: entry.data.image,
  width: 1440,
  format: 'webp',
});

const touristDestinationLd = {
  '@context': 'https://schema.org',
  '@type': 'TouristDestination',
  name: entry.data.country,
  description: pageDescription,
  url: Astro.url.toString(),
  touristType: {
    '@type': 'Audience',
    audienceType: 'Voyageurs indépendants, slow travellers',
  },
  offers: {
    '@type': 'Offer',
    name: "Création d'itinéraire sur mesure",
    url: import.meta.env.PUBLIC_CALENDLY_URL ?? 'https://slowadventures.fr',
    offeredBy: {
      '@type': 'Person',
      name: 'Elena',
      jobTitle: 'Travel Planner',
    },
  },
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  heroPreloadImage={optimizedHero.src}
  ogImage={optimizedHero.src}
  extraLd={touristDestinationLd}
>
  <main id="main">
    <!-- ═══════════════════════════════════════════════
         HERO FULLSCREEN
    ═══════════════════════════════════════════════ -->
    <section
      class="dest-hero relative overflow-hidden"
      aria-label={`Destination ${entry.data.country}`}
    >
      <Image
        src={entry.data.image}
        alt={`Paysage de ${entry.data.country}`}
        widths={[768, 1440, 2880]}
        sizes="100vw"
        loading="eager"
        decoding="async"
        class="dest-hero__img absolute inset-0 w-full h-full object-cover"
      />
      <!-- Gradient overlay -->
      <div
        class="absolute inset-0 bg-linear-to-b from-warm-black/55 via-warm-black/15 to-warm-black/75"
        aria-hidden="true"
      >
      </div>

      <!-- Back nav -->
      <a
        href="/#destinations"
        class="dest-hero__back absolute top-6 left-6 z-20 inline-flex items-center gap-2 text-white/75 hover:text-white transition-colors font-sans text-sm"
        aria-label="Retour aux destinations"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M19 12H5M5 12l7 7M5 12l7-7"></path>
        </svg>
        Toutes les destinations
      </a>

      <!-- Hero text — bottom-anchored -->
      <div
        class="dest-hero__content relative z-10 flex flex-col justify-end items-center text-center px-6 pb-28"
      >
        <div class="dest-hero__text">
          <p
            class="font-sans text-white/70 text-xs uppercase tracking-[0.25em] mb-4"
          >
            Slow Adventures · Travel Planning
          </p>
          <h1
            class="font-serif text-5xl md:text-7xl lg:text-8xl text-white leading-none mb-6"
          >
            {entry.data.country}
          </h1>
          <p
            class="font-sans text-white/85 text-lg md:text-xl max-w-2xl leading-relaxed mx-auto"
          >
            {entry.data.description}
          </p>
        </div>
      </div>

      <ScrollHint />
    </section>

    <!-- ═══════════════════════════════════════════════
         KEYWORDS CHIPS
    ═══════════════════════════════════════════════ -->
    {
      entry.data.keywords && entry.data.keywords.length > 0 && (
        <section
          class="bg-creme px-6 py-10 md:px-12 md:py-14"
          aria-label="Thèmes du voyage"
        >
          <SectionReveal animation="fade-in">
            <div class="max-w-4xl mx-auto flex flex-wrap justify-center gap-3">
              {entry.data.keywords.map((keyword) => (
                <span class="dest-keyword font-sans text-sm px-4 py-2 rounded-full text-warm-black/80 bg-white border border-warm-black/10">
                  {keyword}
                </span>
              ))}
            </div>
          </SectionReveal>
        </section>
      )
    }

    <!-- ═══════════════════════════════════════════════
         CONTENT SECTION
    ═══════════════════════════════════════════════ -->
    <section class="bg-white sa-section-padding" aria-label="Guide destination">
      <SectionReveal animation="fade-up">
        <article class="max-w-3xl mx-auto destination-content">
          <Content />
        </article>
      </SectionReveal>
    </section>

    <!-- ═══════════════════════════════════════════════
         ELENA BAND — gradient terracotta / ambre
    ═══════════════════════════════════════════════ -->
    <section
      class="dest-elena-band sa-section-padding text-center"
      aria-labelledby="dest-elena-heading"
    >
      <SectionReveal animation="scale-in">
        <div class="max-w-2xl mx-auto">
          <p
            class="font-sans text-white/70 text-xs uppercase tracking-[0.2em] mb-5"
          >
            Travel Planning sur mesure
          </p>
          <h2
            id="dest-elena-heading"
            class="font-serif text-3xl md:text-4xl text-white mb-5"
          >
            Je construis cet itinéraire pour toi
          </h2>
          <p class="font-sans text-white/85 text-lg mb-10 leading-relaxed">
            Chaque voyage est unique. Dis-moi tes envies, tes contraintes, tes
            rêves — je m'occupe du reste.
          </p>
          <CTAButton
            href={import.meta.env.PUBLIC_CALENDLY_URL}
            variant="outline"
            text="Réserver un Discovery Call"
            subtext="30 min, gratuit, sans engagement"
          />
        </div>
      </SectionReveal>
    </section>

    <!-- ═══════════════════════════════════════════════
         BACK LINK
    ═══════════════════════════════════════════════ -->
    <div class="text-center py-8 bg-creme">
      <a
        href="/#destinations"
        aria-label="Retour à toutes les destinations"
        class="inline-flex items-center gap-2 font-sans text-warm-black/60 hover:text-terracotta transition-colors text-sm"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M19 12H5M5 12l7 7M5 12l7-7"></path>
        </svg>
        Toutes les destinations
      </a>
    </div>
  </main>
  <CalendlyModal />
</BaseLayout>

<style>
  /* ── Hero ── */
  .dest-hero {
    min-height: 100svh;
    min-height: 100vh;
  }

  .dest-hero__content {
    min-height: 100svh;
    min-height: 100vh;
  }

  .dest-hero__text {
    opacity: 0;
    transform: translateY(32px);
    animation: hero-entrance 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
  }

  .dest-hero__back {
    opacity: 0;
    animation: hero-entrance 0.6s ease-out 0.5s forwards;
  }

  @keyframes hero-entrance {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Keywords chips ── */
  .dest-keyword {
    transition: background-color 0.2s ease;
  }

  .dest-keyword:hover {
    background-color: color-mix(in srgb, var(--color-terracotta) 8%, white);
  }

  /* ── Elena band gradient ── */
  .dest-elena-band {
    background: linear-gradient(
      135deg,
      var(--color-terracotta) 0%,
      var(--color-ambre) 60%,
      color-mix(in srgb, var(--color-ambre) 70%, var(--color-sauge)) 100%
    );
  }

  /* ── Content prose ── */
  .destination-content :global(h2) {
    font-family: var(--font-bree);
    font-size: 1.75rem;
    color: var(--color-warm-black);
    margin-top: 3rem;
    margin-bottom: 1rem;
    line-height: 1.3;
    padding-top: 0.5rem;
    border-top: 2px solid
      color-mix(in srgb, var(--color-terracotta) 15%, transparent);
  }

  .destination-content :global(h3) {
    font-family: var(--font-bree);
    font-size: 1.2rem;
    color: var(--color-terracotta);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .destination-content :global(p) {
    margin-bottom: 1.25rem;
    line-height: 1.85;
    color: var(--color-warm-black);
    font-size: 1.0625rem;
  }

  .destination-content :global(ul),
  .destination-content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .destination-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.75;
    color: var(--color-warm-black);
  }

  .destination-content :global(strong) {
    font-weight: 700;
    color: var(--color-warm-black);
  }

  .destination-content :global(em) {
    font-style: italic;
    color: color-mix(
      in srgb,
      var(--color-terracotta) 80%,
      var(--color-warm-black)
    );
  }

  .destination-content :global(a) {
    color: var(--color-terracotta);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* First paragraph lead style */
  .destination-content :global(p:first-of-type) {
    font-size: 1.175rem;
    color: color-mix(in srgb, var(--color-warm-black) 90%, transparent);
    line-height: 1.9;
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .dest-hero__text,
    .dest-hero__back {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  import { gsap, ScrollTrigger } from '../../lib/gsap';

  // Subtle parallax on hero image while scrolling
  const heroImg = document.querySelector<HTMLElement>('.dest-hero__img');
  if (heroImg) {
    gsap.to(heroImg, {
      yPercent: 20,
      ease: 'none',
      scrollTrigger: {
        trigger: '.dest-hero',
        start: 'top top',
        end: 'bottom top',
        scrub: 1,
      },
    });
  }

  // Cleanup on page transitions (View Transitions API)
  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((st) => st.kill());
  });
</script>
