---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import TopBar from '../components/TopBar.astro';

type JsonLdSchema = { '@context': string; '@type': string; [key: string]: unknown };

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  heroPreloadImage?: string;
  extraLd?: JsonLdSchema;
}

const {
  title,
  description,
  ogImage = '/og-image.jpg',
  heroPreloadImage,
  extraLd,
} = Astro.props;
const siteUrl = Astro.site ?? new URL('https://slowadventures.fr');
const ogImageUrl = new URL(ogImage, siteUrl);
const canonicalUrl = Astro.url;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': ['ProfessionalService', 'TravelAgency'],
  name: 'Slow Adventures',
  description:
    "Slow Adventures est un service de travel planning créé par Elena. Elena conçoit des voyages immersifs et sur mesure dans tous les pays des Amériques — du Canada à la Patagonie en passant par les Caraïbes et l'Amérique centrale.",
  url: siteUrl.toString(),
  image: new URL('/og-image.jpg', siteUrl).toString(),
  logo: new URL('/favicon.svg', siteUrl).toString(),
  founder: {
    '@type': 'Person',
    name: 'Elena',
    jobTitle: 'Travel Planner — Amériques',
  },
  areaServed: {
    '@type': 'Place',
    name: 'Amériques',
    description: 'Tous les pays des Amériques : Amérique du Nord, Amérique centrale, Caraïbes, Amérique du Sud',
  },
  knowsAbout: [
    'travel planning sur mesure',
    'voyages immersifs',
    'itinéraires personnalisés',
    'Amériques du Nord et du Sud',
    'Amérique centrale',
    'Caraïbes',
    'road trip',
    'tourisme slow travel',
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Services Slow Adventures',
    itemListElement: [
      {
        '@type': 'Offer',
        name: 'Discovery Call',
        description:
          "30 minutes pour se connaître, cerner vos rêves et poser les bases d'un voyage personnalisé.",
        price: '0',
        priceCurrency: 'EUR',
        url: siteUrl.toString(),
      },
      {
        '@type': 'Offer',
        name: "Création d'itinéraire sur mesure",
        description:
          "Itinéraire personnalisé complet pour un voyage immersif aux Amériques, ajusté jusqu'à 100% de satisfaction.",
        priceSpecification: {
          '@type': 'PriceSpecification',
          minPrice: '300',
          priceCurrency: 'EUR',
        },
        url: siteUrl.toString(),
      },
    ],
  },
  review: [
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'Antoine et Sophie' },
      reviewBody:
        "Elena a tout organisé au-delà de nos attentes. Chaque jour était une nouvelle découverte, et le fait qu'elle nous assiste par WhatsApp pendant tout le séjour est une vraie valeur ajoutée !",
      name: 'Costa Rica, 12 jours',
    },
    {
      '@type': 'Review',
      author: { '@type': 'Person', name: 'Richard' },
      reviewBody:
        "6 jours à NYC incroyables ! Entre la vue depuis l'Empire State Building, la balade dans Central Park et le coucher de soleil sur le Brooklyn Bridge, chaque moment était magique.",
      name: 'New-York, 6 jours',
    },
  ],
  sameAs: [
    'https://www.instagram.com/slow_adventures_/',
    'https://www.linkedin.com/company/slow-adventures',
  ],
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {
      heroPreloadImage && (
        <link
          rel="preload"
          as="image"
          href={heroPreloadImage}
          type="image/webp"
        />
      )
    }
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Stardos+Stencil:wght@400;700&family=Bree+Serif&display=swap"
      onload="this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Stardos+Stencil:wght@400;700&family=Bree+Serif&display=swap"
        rel="stylesheet"
      />
      <style>
        [data-reveal] {
          opacity: 1 !important;
        }
      </style>
    </noscript>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl.toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:locale" content="fr_FR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl.toString()} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd).replace(/<\/script>/gi, '<\\/script>')} />
    {extraLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(extraLd).replace(/<\/script>/gi, '<\\/script>')} />}
    <!-- Microsoft Clarity -->
    <script is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window,document,"clarity","script","vuosqkypn0");
    </script>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-4NYCND6NTZ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-4NYCND6NTZ');
    </script>
  </head>
  <body class="bg-creme text-warm-black font-sans">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-terracotta focus:text-white focus:px-4 focus:py-2 focus:rounded"
    >
      Aller au contenu
    </a>
    <TopBar />
    <slot />
    <Footer />
    <CookieConsent />
    <script>
      import '../lib/analytics';
    </script>
    <script is:inline>
      // Fallback CSS pour [data-reveal] quand GSAP n'est pas encore chargé
      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );
        document.querySelectorAll('[data-reveal]').forEach(function (el) {
          observer.observe(el);
        });
        // Expose for GSAP coordination (SectionReveal takes over when loaded)
        window.__revealObserver = observer;
      } else {
        document.querySelectorAll('[data-reveal]').forEach(function (el) {
          el.classList.add('revealed');
        });
      }
    </script>
  </body>
</html>
